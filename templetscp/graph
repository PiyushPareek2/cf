//cycle detection using bfs undirected graph
bool bfsHasCycle(int src, vector<vector<int>>& adj, vector<bool>& visited) {
    queue<pair<int, int>> q; // {node, parent}

    visited[src] = true;
    q.push({src, -1});

    while (!q.empty()) {
        auto [u, parent] = q.front();
        q.pop();

        for (int v : adj[u]) {

            // If not visited, visit it
            if (!visited[v]) {
                visited[v] = true;
                q.push({v, u});
            }

            // If visited and not parent, cycle exists
            else if (v != parent) {
                return true;
            }
        }
    }

    return false;
}
//can be disconnected so make sure check everynode
bool hasCycle(int n, vector<vector<int>>& adj) {
    vector<bool> visited(n, false);
    for (int i = 1; i <= n; i++) {
        if (!visited[i]) {
            if (bfsHasCycle(i, adj, visited)) return true;
        }
    }
    return false;
}
