bool isbarpatite(int src,vector<int>& color){

    queue<int> q;

    q.push(src);
    color[src]=0;

    while(!q.empty()){

        int node=q.front();
        q.pop();

        for(int neigh:adj[node]){

            if(color[neigh]==-1){

                color[neigh]=1-color[node];
                q.push(neigh);
            }

            else if(color[neigh]==color[node])
                return false;
        }
    }

    return true;
}


